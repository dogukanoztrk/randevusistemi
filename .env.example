# ==========================================
# DiTA Appointment App - Environment Setup
# ==========================================

# General System Settings
APP_ENV=development
TZ=Europe/Istanbul

# Database Configuration
# For production, you might want to use PostgreSQL: postgresql://user:pass@localhost/dbname
SQLALCHEMY_DATABASE_URL=sqlite:///./dita_appointments.db

# Security & Authentication
# MUST BE CHANGED IN PRODUCTION! Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your_super_secret_jwt_key_here
